  unfold g
  exact abs_nonneg _

lemma support_g_eq : Function.support g = {x | g x > 0} := by
  ext x
  constructor
  · intro hx
    have : g x ≠ 0 := hx
    exact lt_of_le_of_ne (g_nonneg x) this.symm
  · intro hx
    exact ne_of_gt hx

