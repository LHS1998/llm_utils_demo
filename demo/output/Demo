    (h_int2 : ∫ z in D, (z.1 * z.2) * f z = 1) :
    ∃ (ξ η : ℝ), ((ξ, η) ∈ D) ∧ |f (ξ, η)| ≥ 1 / b := by
  -- 反证法：假设对所有点都有 |f| < 1/b
  by_contra! H  -- H : ∀ (ξ η : ℝ), (ξ, η) ∈ D → |f (ξ, η)| < 1 / b
  -- 转换为 ∀ z ∈ D, |f z| < 1/b
  have h_bound : ∀ z ∈ D, |f z| < 1 / b := by
    intro z hz
